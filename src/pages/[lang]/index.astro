---
import Layout from "@/components/Layout.astro";
import ToolCard from "@/components/ToolCard.astro";
import { getCategoryItems, getTools, i18n, languages, type Lang } from "@/i18n/translations";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = i18n[lang];
const featured = getTools(lang).slice(0, 8);
const categories = getCategoryItems(lang);
const otherLang = lang === "ko" ? "en" : "ko";
---

<Layout
  title={t.home.title}
  description={t.home.description}
  canonical={`/${lang}`}
  lang={lang}
  alternates={[
    { lang: otherLang, href: `/${otherLang}` },
    { lang: "x-default", href: "/ko" },
  ]}
>
  <section class="grid gap-8 md:grid-cols-[minmax(0,1fr)_340px] md:items-center md:gap-12 lg:gap-14">
    <div>
      <p class="text-sm font-semibold text-brand">{t.home.label}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-normal md:text-5xl">{t.home.h1}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-700">{t.home.body1}</p>
      <p class="mt-4 text-base leading-7 text-slate-700">{t.home.body2}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`/${lang}/tools`} class="rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white no-underline">{t.home.button}</a>
      </div>
    </div>
    <div class="w-full rounded-lg border border-line bg-panel p-5 md:max-w-[340px] md:justify-self-end">
      <h2 class="text-lg font-bold">{t.home.frequent}</h2>
      <div class="mt-4 grid gap-3">
        {featured.slice(0, 5).map((tool) => (
          <a href={tool.path} class="rounded-md bg-white p-3 text-sm font-semibold text-ink no-underline shadow-sm">
            {tool.slug === "case-converter" && lang === "ko" ? "영문 대소문자 변환기" : tool.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold">{t.home.categories}</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-5">
      {categories.map((category) => (
        <a href={category.path} class="rounded-lg border border-line bg-white p-4 text-ink no-underline shadow-sm">
          <p class="font-semibold">{category.name}</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">{category.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold">{t.home.featured}</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-4">
      {featured.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>
</Layout>
