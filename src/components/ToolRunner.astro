---

<div class="tool-panel" data-tool={slug} data-lang={lang}>
  {["character-counter", "remove-spaces", "case-converter", "json-formatter", "base64-converter", "qr-code-generator", "url-encoder-decoder", "csv-json-converter"].includes(slug) && (
    <div class="grid gap-4">
      <label class="font-semibold" for="text-input">{ui.input}</label>
      <textarea id="text-input" placeholder={ui.placeholder}></textarea>
      {slug === "remove-spaces" && (
        <select id="mode">
          <option value="trim">{ui.modes.trim}</option>
          <option value="trim-lines">{ui.modes.trimLines}</option>
          <option value="all">{ui.modes.allSpaces}</option>
          <option value="line">{ui.modes.lineBreaks}</option>
        </select>
      )}
      {slug === "case-converter" && (
        <select id="mode">
          <option value="upper">{ui.modes.upper}</option>
          <option value="lower">{ui.modes.lower}</option>
          <option value="title">{ui.modes.title}</option>
        </select>
      )}
      <div class="flex flex-wrap gap-2">
        <button class="btn-primary" data-action="run">{slug === "url-encoder-decoder" ? ui.encode : slug === "csv-json-converter" ? ui.toJson : ui.run}</button>
        {slug === "json-formatter" && <button class="btn-secondary" data-action="compact">{ui.compact}</button>}
        {slug === "base64-converter" && <button class="btn-secondary" data-action="decode">{ui.decode}</button>}
        {slug === "url-encoder-decoder" && <button class="btn-secondary" data-action="decode">{ui.decode}</button>}
        {slug === "csv-json-converter" && <button class="btn-secondary" data-action="to-csv">{ui.toCsv}</button>}
        <button class="btn-secondary" data-action="copy">{ui.copyResult}</button>
        <button class="btn-secondary" data-action="reset">{ui.reset}</button>
      </div>
      {slug === "qr-code-generator" && <canvas id="qr-canvas" class="h-48 w-48 rounded-md border border-line bg-white p-2"></canvas>}
      <pre class="result-box whitespace-pre-wrap" id="result">{ui.result}</pre>
    </div>
  )}

  {["image-resizer", "image-compressor", "webp-converter", "image-cropper", "image-rotate-flip", "image-format-converter", "image-mosaic", "image-watermark", "remove-image-metadata", "image-color-picker"].includes(slug) && (
    <div class="grid gap-4">
      <label class="font-semibold" for="image-file">{ui.labels.imageFile}</label>
      <input id="image-file" type="file" accept={slug === "webp-converter" ? "image/jpeg,image/png" : "image/jpeg,image/png,image/webp"} />

      {slug === "image-resizer" && (
        <div class="grid gap-4 md:grid-cols-3">
          <label>{ui.labels.width}<input id="width" type="number" inputmode="numeric" min="1" /></label>
          <label>{ui.labels.height}<input id="height" type="number" inputmode="numeric" min="1" /></label>
          <label class="flex items-center gap-2 pt-6"><input id="keep-ratio" class="w-auto" type="checkbox" checked />{ui.labels.keepRatio}</label>
        </div>
      )}

      {["image-compressor", "webp-converter"].includes(slug) && (
        <label>{ui.labels.quality}<input id="quality" type="range" min="10" max="100" value="80" /></label>
      )}

      {slug === "image-cropper" && (
        <div class="grid gap-4 md:grid-cols-3">
          <label>{ui.labels.aspectRatio}<select id="aspect-ratio"><option value="free">{lang === "ko" ? "자유 비율" : "Free"}</option><option value="1:1">1:1</option><option value="4:3">4:3</option><option value="16:9">16:9</option></select></label>
          <label>{ui.labels.cropX}<input id="crop-x" type="number" inputmode="numeric" min="0" value="0" /></label>
          <label>{ui.labels.cropY}<input id="crop-y" type="number" inputmode="numeric" min="0" value="0" /></label>
          <label>{ui.labels.cropWidth}<input id="crop-width" type="number" inputmode="numeric" min="1" /></label>
          <label>{ui.labels.cropHeight}<input id="crop-height" type="number" inputmode="numeric" min="1" /></label>
        </div>
      )}

      {slug === "image-rotate-flip" && (
        <div class="flex flex-wrap gap-2">
          <button class="btn-secondary" data-action="rotate-left">{lang === "ko" ? "왼쪽으로 90도" : "Rotate Left 90"}</button>
          <button class="btn-secondary" data-action="rotate-right">{lang === "ko" ? "오른쪽으로 90도" : "Rotate Right 90"}</button>
          <button class="btn-secondary" data-action="rotate-180">{lang === "ko" ? "180도 회전" : "Rotate 180"}</button>
          <button class="btn-secondary" data-action="flip-horizontal">{lang === "ko" ? "좌우 뒤집기" : "Flip Horizontal"}</button>
          <button class="btn-secondary" data-action="flip-vertical">{lang === "ko" ? "상하 뒤집기" : "Flip Vertical"}</button>
          <button class="btn-secondary" data-action="reset">{ui.reset}</button>
        </div>
      )}

      {slug === "image-format-converter" && (
        <div class="grid gap-4 md:grid-cols-2">
          <label>{ui.labels.outputFormat}<select id="output-format"><option value="image/jpeg">JPG</option><option value="image/png">PNG</option><option value="image/webp">WebP</option></select></label>
          <label>{ui.labels.quality}<input id="quality" type="range" min="10" max="100" value="80" /></label>
        </div>
      )}

      {slug === "image-mosaic" && (
        <div class="grid gap-4">
          <div class="grid gap-4 md:grid-cols-5">
            <label>{ui.labels.mosaicSize}<select id="mosaic-size"><option value="4">4px</option><option value="8">8px</option><option value="12" selected>12px</option><option value="16">16px</option><option value="24">24px</option><option value="32">32px</option><option value="40">40px</option></select></label>
            <label>{ui.labels.selectionX}<input id="mosaic-x" type="number" readonly value="0" /></label>
            <label>{ui.labels.selectionY}<input id="mosaic-y" type="number" readonly value="0" /></label>
            <label>{ui.labels.selectionWidth}<input id="mosaic-width" type="number" readonly value="0" /></label>
            <label>{ui.labels.selectionHeight}<input id="mosaic-height" type="number" readonly value="0" /></label>
          </div>
          <p class="text-sm text-slate-600">{lang === "ko" ? "미리보기 위에서 사각형 영역을 드래그해 선택합니다. 모바일에서는 손가락으로 드래그할 수 있습니다." : "Drag a rectangle over the preview. Touch dragging is supported on mobile browsers where available."}</p>
          <div class="overflow-auto rounded-md border border-line bg-white p-2">
            <canvas id="mosaic-canvas" class="max-h-[560px] max-w-full touch-none"></canvas>
          </div>
          <div class="flex flex-wrap gap-2">
            <button class="btn-primary" data-action="apply-mosaic">{lang === "ko" ? "모자이크 적용" : "Apply Mosaic"}</button>
            <button class="btn-secondary" data-action="reset">{ui.reset}</button>
          </div>
        </div>
      )}

      {slug === "image-watermark" && (
        <div class="grid gap-4 md:grid-cols-3">
          <label class="md:col-span-3">{ui.labels.overlayText}<textarea id="overlay-text" placeholder="Toolbox"></textarea></label>
          <label>{ui.labels.position}<select id="text-position"><option value="top-left">{lang === "ko" ? "좌상단" : "Top left"}</option><option value="top-right">{lang === "ko" ? "우상단" : "Top right"}</option><option value="center">{lang === "ko" ? "중앙" : "Center"}</option><option value="bottom-left">{lang === "ko" ? "좌하단" : "Bottom left"}</option><option value="bottom-right">{lang === "ko" ? "우하단" : "Bottom right"}</option></select></label>
          <label>{ui.labels.fontSize}<input id="font-size" type="number" min="8" value="36" /></label>
          <label>{ui.labels.textColor}<input id="text-color" type="color" value="#ffffff" /></label>
          <label>{ui.labels.opacity}<input id="text-opacity" type="range" min="10" max="100" value="60" /></label>
          <label>{ui.labels.rotation}<input id="text-rotation" type="number" min="-180" max="180" value="0" /></label>
        </div>
      )}

      {slug === "remove-image-metadata" && (
        <p class="text-sm text-slate-600">{lang === "ko" ? "브라우저 canvas로 다시 저장하는 방식은 대부분의 이미지 메타데이터를 제거하지만, 모든 형식의 메타데이터 제거를 보장하지는 않습니다." : "Re-saving through a browser canvas removes most image metadata, but it may not guarantee removal of every metadata field."}</p>
      )}

      {slug === "image-color-picker" && (
        <div class="grid gap-3">
          <p class="text-sm text-slate-600">{lang === "ko" ? "이미지를 선택한 뒤 미리보기에서 색상을 알고 싶은 지점을 클릭하세요." : "Select an image, then click a point in the preview to pick its color."}</p>
          <div class="overflow-auto rounded-md border border-line bg-white p-2">
            <canvas id="color-canvas" class="max-h-[560px] max-w-full cursor-crosshair"></canvas>
          </div>
          <div><button class="btn-secondary" data-action="copy">{ui.copyResult}</button></div>
          <div id="recent-colors" class="flex flex-wrap gap-2"></div>
        </div>
      )}

      <div class={`grid gap-4 ${slug === "image-color-picker" ? "" : "md:grid-cols-2"}`}>
        {slug !== "image-color-picker" && (
          <div>
            <p class="text-sm font-semibold text-slate-600">{lang === "ko" ? "미리보기" : "Preview"}</p>
            <img id="image-preview" alt={lang === "ko" ? "처리된 이미지 미리보기" : "Processed image preview"} class="mt-2 max-h-96 w-full rounded-md border border-line object-contain" />
          </div>
        )}
        <div>
          <p class="text-sm font-semibold text-slate-600">{lang === "ko" ? "처리 결과" : "Processing Result"}</p>
          <pre class="result-box mt-2 whitespace-pre-wrap" id="result">{ui.result}</pre>
          <a id="download-link" class="btn-primary mt-3 hidden w-fit" download>{lang === "ko" ? "다운로드" : "Download"}</a>
        </div>
      </div>
    </div>
  )}

  {slug === "audio-converter" && (
    <div class="grid gap-4">
