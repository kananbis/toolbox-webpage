---
import type { Lang } from "@/i18n/translations";
import { ADSENSE_SLOTS, SITE_CONFIG } from "../../site.config.mjs";

type Placement = keyof typeof ADSENSE_SLOTS;

type Props = {
  lang?: Lang;
  placement?: Placement;
  slot?: string;
  format?: string;
  className?: string;
};

const { lang = "ko", placement = "toolTop", slot, format = "auto", className = "" } = Astro.props;
const slotId = slot ?? ADSENSE_SLOTS[placement] ?? "";
const enabled = SITE_CONFIG.enableAdsense && SITE_CONFIG.adsenseClientId && slotId;
const label = lang === "ko" ? "\uAD11\uACE0" : "Advertisement";
---

<aside class:list={["my-8 overflow-hidden rounded-lg border border-dashed border-line bg-panel p-4 text-center text-xs text-slate-500", className]}>
  <p class="mb-3">{label}</p>
  {
    enabled ? (
      <>
        <ins
          class="adsbygoogle block min-h-[90px]"
          style="display:block"
          data-ad-client={SITE_CONFIG.adsenseClientId}
          data-ad-slot={slotId}
          data-ad-format={format}
          data-full-width-responsive="true"
        />
        <script is:inline>
          try {
            (window.adsbygoogle = window.adsbygoogle || []).push({});
          } catch (_) {}
        </script>
      </>
    ) : (
      <div class="min-h-[90px] rounded-md bg-white/60" aria-label={label}>
        <span class="sr-only">{label}</span>
      </div>
    )
  }
</aside>
