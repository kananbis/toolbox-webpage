---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { isLang, type Lang } from "@/i18n/translations";
import { SITE_CONFIG } from "../../site.config.mjs";
import "@/styles/global.css";

type Props = {
  title: string;
  description: string;
  canonical?: string;
  lang?: Lang;
  alternates?: { lang: Lang | "x-default"; href: string }[];
};

const segments = Astro.url.pathname.split("/").filter(Boolean);
const inferredLang: Lang = isLang(segments[0]) ? segments[0] : "ko";
const { title, description, canonical = Astro.url.pathname, lang = inferredLang, alternates = [] } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, "") ?? SITE_CONFIG.siteUrl;
const normalizePath = (href: string) => {
  const path = href.startsWith("http") ? new URL(href).pathname : href;
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  return cleanPath.endsWith("/") ? cleanPath : `${cleanPath}/`;
};
const canonicalPath = normalizePath(canonical);
const canonicalUrl = `${site}${canonicalPath}`;
const languageAlternateItems = [{ lang, href: canonicalPath }, ...alternates.filter((item) => item.lang !== "x-default")].map((item) => ({
  ...item,
  href: normalizePath(item.href),
}));
const dedupedLanguageAlternateItems = languageAlternateItems.filter(
  (item, index, items) => items.findIndex((candidate) => candidate.lang === item.lang) === index,
);
const defaultPath = lang === "ko" ? canonicalPath : dedupedLanguageAlternateItems.find((item) => item.lang === "ko")?.href ?? "/ko/";
const alternateItems = [...dedupedLanguageAlternateItems, { lang: "x-default" as const, href: defaultPath }];
const absoluteUrl = (href: string) => `${site}${normalizePath(href)}`;
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateItems.map((item) => <link rel="alternate" hreflang={item.lang} href={absoluteUrl(item.href)} />)}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {
      gaMeasurementId && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`} />
          <script is:inline define:vars={{ gaMeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaMeasurementId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-6xl px-4 py-8 md:py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
