---
import Layout from "@/components/Layout.astro";
import { i18n, languages, type Lang } from "@/i18n/translations";
import { SITE_CONFIG } from "../../../site.config.mjs";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = i18n[lang];
const otherLang = lang === "ko" ? "en" : "ko";
const contactEmail = SITE_CONFIG.contactEmail;
const title = lang === "ko" ? `개인정보처리방침 - ${t.siteName}` : `Privacy Policy - ${t.siteName}`;
const description =
  lang === "ko"
    ? "Toolbox 개인정보처리방침입니다. 입력값과 선택한 파일은 기본적으로 서버로 업로드되지 않고 브라우저에서 처리됩니다."
    : "Privacy policy for Toolbox. User input and selected files are generally processed in the browser and are not uploaded to a server.";
---

<Layout
  title={title}
  description={description}
  canonical={`/${lang}/privacy`}
  lang={lang}
  alternates={[{ lang: otherLang, href: `/${otherLang}/privacy` }, { lang: "x-default", href: "/ko/privacy" }]}
>
  <article class="prose-lite max-w-3xl">
    <h1 class="text-3xl font-bold">{lang === "ko" ? "개인정보처리방침" : "Privacy Policy"}</h1>
    {
      lang === "ko" ? (
        <>
          <p class="mt-4">Toolbox는 텍스트, 계산값, 선택한 이미지 파일을 가능한 한 현재 브라우저 안에서 처리하도록 설계되어 있습니다.</p>
          <h2>입력값과 파일 처리</h2>
          <p>입력한 내용과 선택한 파일은 기본적으로 서버로 업로드되지 않으며, 현재 브라우저 안에서만 처리됩니다. 도구 결과를 생성하기 위해 별도의 계정이나 로그인 정보도 요구하지 않습니다.</p>
          <h2>쿠키와 분석 도구</h2>
          <p>이 사이트는 서비스 이용 현황을 파악하기 위해 Google Analytics와 같은 분석 도구를 사용할 수 있습니다. 이 과정에서 쿠키 또는 유사 기술이 사용될 수 있습니다.</p>
          <h2>광고 서비스</h2>
          <p>이 사이트는 향후 Google AdSense와 같은 제3자 광고 서비스를 사용할 수 있습니다. 이 경우 광고 제공자는 쿠키 또는 유사 기술을 사용해 사용자의 방문 정보에 기반한 광고를 제공할 수 있습니다.</p>
          <h2>문의</h2>
          <p>
            개인정보 관련 문의는{" "}
            {contactEmail ? <a href={`mailto:${contactEmail}`}>{contactEmail}</a> : "Contact 페이지에 안내된 이메일"}
            로 연락해 주세요.
          </p>
        </>
      ) : (
        <>
          <p class="mt-4">Toolbox is designed to process text, calculation values, and selected image files in your current browser whenever possible.</p>
          <h2>Input and File Processing</h2>
          <p>Your input and selected files are generally not uploaded to a server and are processed only in your browser. The tools do not require an account or login to generate results.</p>
          <h2>Cookies and Analytics</h2>
          <p>This site may use analytics tools such as Google Analytics to understand site usage. Cookies or similar technologies may be used for this purpose.</p>
          <h2>Advertising Services</h2>
          <p>This site may use third-party advertising services such as Google AdSense. These providers may use cookies or similar technologies to serve ads based on users visits.</p>
          <h2>Contact</h2>
          <p>
            For privacy-related questions, contact us through{" "}
            {contactEmail ? <a href={`mailto:${contactEmail}`}>{contactEmail}</a> : "the email shown on the Contact page"}.
          </p>
        </>
      )
    }
  </article>
</Layout>
