        event.preventDefault();
        mosaicCanvas.setPointerCapture?.(event.pointerId);
        startPoint = pointOnCanvas(mosaicCanvas, event);
        isDragging = true;
        setMosaicSelection(root, { x: startPoint.x, y: startPoint.y, width: 0, height: 0 });
        drawMosaicPreview(root);
      });
      mosaicCanvas.addEventListener("pointermove", (event) => {
        if (!isDragging || !startPoint) return;
        event.preventDefault();
        const point = pointOnCanvas(mosaicCanvas, event);
        const selection = {
          x: Math.min(startPoint.x, point.x),
          y: Math.min(startPoint.y, point.y),
          width: Math.abs(point.x - startPoint.x),
          height: Math.abs(point.y - startPoint.y),
        };
        setMosaicSelection(root, selection);
        drawMosaicPreview(root);
      });
      const stopMosaicDrag = async (event) => {
        if (!isDragging) return;
        event.preventDefault();
        isDragging = false;
        startPoint = null;
        drawMosaicPreview(root);
        try {
          await refreshMosaicOutput(root);
        } catch (error) {
          root.querySelector("#result").textContent = error instanceof Error ? error.message : messages[root.dataset.lang || "ko"].checkInput;
        }
      };
      mosaicCanvas.addEventListener("pointerup", stopMosaicDrag);
      mosaicCanvas.addEventListener("pointercancel", stopMosaicDrag);
    }
    const colorCanvas = root.querySelector("#color-canvas");
    if (colorCanvas) {
      colorCanvas.addEventListener("click", (event) => {
        pickCanvasColor(root, event).catch((error) => {
          root.querySelector("#result").textContent = error instanceof Error ? error.message : messages[root.dataset.lang || "ko"].checkInput;
        });
      });
    }
    syncDynamicInputs(root);
    if (selectOnlyAutoRunSlugs.has(slug)) autoRun();
  });
</script>
