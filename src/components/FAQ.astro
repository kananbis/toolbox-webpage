---
type Props = { items: { question: string; answer: string }[] };
const { items } = Astro.props;
---

<section class="prose-lite">
  <h2>FAQ</h2>
  <div class="mt-4 divide-y divide-line rounded-lg border border-line bg-white">
    {items.map((item) => (
      <details class="group p-4">
        <summary class="cursor-pointer font-semibold text-ink">{item.question}</summary>
        <p class="mt-3 text-slate-700">{item.answer}</p>
      </details>
    ))}
  </div>
</section>
